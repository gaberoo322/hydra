  "license": "UNLICENSED",
  "dependencies": {
    "@openai/codex-sdk": "^0.125.0",
    "@sentry/node": "^10.48.0",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "typescript": "^6.0.2"
  }
}
