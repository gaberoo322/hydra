node_modules/
.env
*.log
dist/
.ov-staging/
/metrics/

# Python bytecode caches (see issue #717) — never commit compiled artifacts.
__pycache__/
*.pyc

# Secrets / credentials — never commit (repo is public; see issue #698).
# .env.example is the only env file that should be tracked.
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.crt
credentials.json
secrets.json
.netrc

# Thermo-nuclear code quality review (local-only)
.thermonuclear/

# Agent worktrees — local per-dispatch git worktrees, never committed
.claude/worktrees/

# Volatile scheduled-tasks lock (see issue #867) — regenerated by the Claude Code
# harness on every lock acquisition; untracking it keeps the deploy root clean so
# the deploy.sh dirty-tree guard stops tripping. Exact path, not a .claude glob,
# to avoid shadowing the .claude/worktrees/ rule or ignoring other tracked .claude/ paths.
.claude/scheduled_tasks.lock

# Per-test TAP artifact from `npm run test:debug` (issue #1076) — regenerated
# on every debug run, never committed.
test-debug.tap

# Generated config artifacts (issue #1739) — runtime output that keeps showing
# up as untracked in the main ~/hydra tree, tripping the deploy.sh dirty-tree
# guard (post-#551 contract) and giving agents grounding against ~/hydra phantom
# diffs. Ignore ONLY the generated paths — config/ is otherwise git-tracked by
# convention, and config/feedback/ is a Tier-1 prompt/lesson convention path
# (CLAUDE.md), so we never blanket-ignore that directory.
#
# config/digests/ has never been tracked: hydra-digest writes daily/on-demand
# summary .md files here and hydra-retro writes per-run retro JSON under retro/.
# The whole directory is generated.
config/digests/
#
# Under config/feedback/, ignore only the generated subpaths:
#   - to-*.md          : the LIVE Pattern-Memory learning files (to-planner.md,
#                        to-executor.md, to-skeptic.md) the promotion lifecycle
#                        (src/pattern-memory/feedback-file.ts) writes on disk. The
#                        tracked SOURCE moved to docs/historical/ when config/feedback/
#                        was retired from the repo (#710); on-disk copies are runtime.
#   - retro-artifacts/ : per-run retro JSON dumps written by hydra-retro.
#   - *-iotest.md      : promotion-lifecycle integration-test artifacts (#1125).
config/feedback/to-*.md
config/feedback/retro-artifacts/
config/feedback/*-iotest.md
