node_modules/
.env
*.log
dist/
.ov-staging/
/metrics/

# Python bytecode caches (see issue #717) — never commit compiled artifacts.
__pycache__/
*.pyc

# Secrets / credentials — never commit (repo is public; see issue #698).
# .env.example is the only env file that should be tracked.
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.crt
credentials.json
secrets.json
.netrc

# Thermo-nuclear code quality review (local-only)
.thermonuclear/

# Agent worktrees — local per-dispatch git worktrees, never committed
.claude/worktrees/

# Volatile scheduled-tasks lock (see issue #867) — regenerated by the Claude Code
# harness on every lock acquisition; untracking it keeps the deploy root clean so
# the deploy.sh dirty-tree guard stops tripping. Exact path, not a .claude glob,
# to avoid shadowing the .claude/worktrees/ rule or ignoring other tracked .claude/ paths.
.claude/scheduled_tasks.lock
