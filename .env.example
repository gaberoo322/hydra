# Required
HYDRA_PORT=4000
REDIS_URL=redis://localhost:6379
HYDRA_PROJECT_WORKSPACE=/path/to/your/project
HYDRA_VAULT_PATH=/path/to/obsidian-vault

# Scheduler
HYDRA_AUTO_CYCLE_INTERVAL_MS=300000           # Auto-run cycles every N ms (0 = disabled)
HYDRA_CYCLE_TTL_MS=5400000                    # Cycle timeout (default: 90 min)

# Research
HYDRA_RESEARCH_QUEUE_THRESHOLD=3              # Trigger research when queue below this
HYDRA_RESEARCH_MIN_INTERVAL_MS=43200000       # Min time between research cycles (default: 12h)
HYDRA_ARCHITECT_EVERY_N_RESEARCH=3            # Run architect review every N research cycles
HYDRA_APP_METRICS_URL=                        # Optional: URL to fetch app metrics JSON

# Agent runtime
HYDRA_AGENTS_PATH=/path/to/agency-agents      # Agent personality base files
HYDRA_ORCHESTRATOR_PATH=/path/to/hydra        # Path to this repo (for Meta agent)
OPENAI_PROXY_PORT=4001                        # OpenAI API proxy port
CODEX_BIN=codex                               # Path to codex CLI binary

# Notifications (optional)
OPENCLAW_TELEGRAM_TARGET=your_chat_id
OPENCLAW_GATEWAY_TOKEN=your_token
