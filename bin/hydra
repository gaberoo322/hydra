#!/usr/bin/env bash
#
# hydra â€” thin CLI wrapper around the orchestrator's HTTP API.
#
# Skills (hydra-autopilot, hydra-doctor, hydra-sweep, etc.) call `hydra <cmd>`
# from their bash collectors. Until this file existed, those calls failed
# silently and the skills fell back to raw curl / docker exec â€” fragile.
#
# All subcommands print JSON on stdout (or plain text where the API returns
# plain text). Callers pipe through `python3 -c 'import json,sys; â€¦'` or `jq`.
#
# Override the API base via HYDRA_BASE_URL (default: http://localhost:4000).
#
# Usage examples:
#   hydra health
#   hydra health deep
#   hydra scheduler status
#   hydra scheduler start | stop
#     stop semantics (issue #385): drains the in-flight cycle, no chained
#     ticks fire after the response â€” scheduler is quiescent the instant
#     stop returns. Safe to call repeatedly; second call returns "not running".
#   hydra brake on | off | status
#     Operator-only emergency brake (issue #744). `on` pauses ALL auto-merge
#     regardless of tier/depth and routes open PRs to /hydra-review; `off`
#     resumes ADR-0015 depth-gated merge; `status` reads the current state.
#     This CLI is the ONLY write path â€” the autopilot can never set/clear it.
#   hydra cycle status
#   hydra cycle start
#   hydra backlog ls | counts | move <id> <lane>
#     move semantics (issue #537): PATCHes `/backlog/:id/move` with
#     `{"lane": "<lane>"}`. Pre-fix, the CLI PATCHed `/backlog/:id` which
#     routes to `updateItem` â€” and `updateItem`'s ALLOWED list does not
#     include `lane`, so every move silently no-op'd while returning
#     `ok:true`. Always use this command (or `hydra raw PATCH
#     /backlog/<id>/move --json '{"lane":"<lane>"}'`) â€” never PATCH the
#     bare `/backlog/<id>` to change a lane.
#   hydra queue ls | add <reference>
#   hydra metrics [--count N]
#   hydra alerts ls [--limit N]
#   hydra recommendations
#   hydra research start | force | history
#   hydra raw GET <path>
#   hydra raw POST <path> ['<body>' | --json '<body>']
#   hydra raw PATCH <path> ('<body>' | --json '<body>')
#     body semantics (issue #779): the request body may be supplied either
#     positionally (`hydra raw POST /x '{"a":1}'`) OR via --json. Pre-fix,
#     only --json was honoured â€” a positional body was silently dropped and
#     an EMPTY body was POSTed, which is why every dev_target state-sync
#     write (all positional) 400'd with "Missing cycleId". curl -d forwards
#     the body byte-for-byte, so multi-line JSON works without --json. A
#     bodyless POST (e.g. /merge/unlock) is still valid.

set -eu

BASE_URL="${HYDRA_BASE_URL:-http://localhost:4000}"

usage() {
  sed -n '/^# Usage examples:/,/^$/p' "$0" | sed 's/^# \?//'
  exit "${1:-2}"
}

# Wrappers â€” curl with sane defaults. -sS hides the progress bar but still
# surfaces errors on stderr. We do NOT use -f so callers can see 4xx/5xx
# JSON bodies that may contain useful error context.
#
# _get separates the body from the HTTP status (using `-w` with a sentinel
# trailing line), then refuses to print HTML 404 pages as if they were data
# (issue #448). On non-2xx OR when the body looks like HTML, it writes the
# response to stderr and exits non-zero so callers can detect the failure
# without parsing the payload. This regressed silently after the cycles
# router moved to `/cycle/:cycleId/reality` and the CLI kept GETting the
# stale `/cycle/reality` path â€” every call returned the Express 404 page.
_get() {
  local response status body
  # %{http_code} on the last line lets us split the body cleanly even when
  # the response itself contains newlines. Use a sentinel to avoid relying
  # on the body NOT ending in three digits.
  response="$(curl -sS -w '\nHYDRA_HTTP_CODE:%{http_code}' "$BASE_URL/api$1")" || return $?
  status="${response##*HYDRA_HTTP_CODE:}"
  body="${response%$'\n'HYDRA_HTTP_CODE:*}"
  case "$status" in
    2??) ;;
    *) echo "hydra: GET $1 failed with HTTP $status" >&2
       printf '%s\n' "$body" >&2
       return 1 ;;
  esac
  # Some routes (e.g. Express's default 404) reply 200 with HTML in dev
  # configurations or behind proxies. Refuse to treat HTML as data so
  # callers that pipe through jq/python don't blow up on `<html>...`.
  case "$body" in
    "<!DOCTYPE"*|"<!doctype"*|"<html"*|"<HTML"*)
      echo "hydra: GET $1 returned HTML (expected JSON/text)" >&2
      printf '%s\n' "$body" >&2
      return 1 ;;
  esac
  printf '%s\n' "$body"
}
_post()   { local p="$1"; shift; if [ "$#" -gt 0 ]; then curl -sS -X POST -H 'content-type: application/json' -d "$1" "$BASE_URL/api$p"; else curl -sS -X POST "$BASE_URL/api$p"; fi; }
_patch()  { curl -sS -X PATCH -H 'content-type: application/json' -d "$2" "$BASE_URL/api$1"; }
_delete() { curl -sS -X DELETE "$BASE_URL/api$1"; }

cmd_health() {
  case "${1:-}" in
    deep) _get "/health/deep" ;;
    ""  ) _get "/health" ;;
    *   ) echo "hydra health: unknown sub '$1'" >&2; exit 2 ;;
  esac
}

cmd_scheduler() {
  case "${1:-}" in
    status) _get "/scheduler/status" ;;
    start ) _post "/scheduler/start" ;;
    stop  ) _post "/scheduler/stop" ;;
    *     ) echo "hydra scheduler: need status|start|stop" >&2; exit 2 ;;
  esac
}

# Issue #744: operator-only emergency brake. `on` pauses ALL auto-merge and
# routes open PRs to /hydra-review; `off` resumes ADR-0015 depth-gated merge;
# `status` reads the current state. This CLI (the operator plane) is the ONLY
# write path â€” the autopilot can never engage/disengage the brake.
cmd_brake() {
  case "${1:-}" in
    on    ) _post "/autopilot/emergency-brake" '{"engaged":true,"engagedBy":"cli"}' ;;
    off   ) _post "/autopilot/emergency-brake" '{"engaged":false}' ;;
    status|"") _get "/autopilot/emergency-brake" ;;
    *     ) echo "hydra brake: need on|off|status" >&2; exit 2 ;;
  esac
}

cmd_cycle() {
  case "${1:-}" in
    status ) _get "/cycle/status" ;;
    start  ) _post "/cycle/start" ;;
    history)
      shift
      local q=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --limit) q="?limit=$2"; shift 2 ;;
          *) shift ;;
        esac
      done
      _get "/cycle/history${q}" ;;
    *      ) echo "hydra cycle: need status|start|history" >&2; exit 2 ;;
  esac
}

cmd_backlog() {
  case "${1:-}" in
    ls|""  ) _get "/backlog" ;;
    counts ) _get "/backlog/counts" ;;
    move   )
      shift
      [ "$#" -ge 2 ] || { echo "hydra backlog move: need <id> <lane>" >&2; exit 2; }
      # Issue #1140: LANES (src/backlog/internal.ts) is camelCase
      # (triage|backlog|queued|blocked|inProgress|done). Agents/operators
      # keep typing lowercase `inprogress` / `in-progress`, which the server
      # rejects with `Invalid lane`. Alias-normalize the common variants to
      # the canonical camelCase before sending so muscle-memory casing works;
      # any other value is forwarded verbatim and the server validates it.
      local lane="$2"
      local lane_lc
      lane_lc="$(printf '%s' "$lane" | tr '[:upper:]' '[:lower:]')"
      if [ "$lane_lc" = "inprogress" ] || [ "$lane_lc" = "in-progress" ] || [ "$lane_lc" = "in_progress" ]; then
        lane="inProgress"
      fi
      # Issue #537: the move sub-route is `/backlog/:id/move`. Hitting
      # `/backlog/:id` (updateItem) silently drops `lane` because it's not
      # on updateItem's ALLOWED list â€” every move returned ok:true while
      # the backlog state was unchanged. Always use the /move suffix.
      _patch "/backlog/$1/move" "{\"lane\":\"$lane\"}" ;;
    *      ) echo "hydra backlog: need ls|counts|move" >&2; exit 2 ;;
  esac
}

cmd_queue() {
  case "${1:-}" in
    ls|"") _get "/queue" ;;
    add )
      shift
      # Issue #1140: accept the reason via EITHER a `-d <reason>` flag (curl
      # muscle-memory, the form every playbook already writes) OR the second
      # positional argument. The first non-flag arg is the <reference>; a
      # bare positional after it remains a valid reason (backward-compatible).
      # Pre-fix, `hydra queue add "<title>" -d "<why>"` put `-d` into the
      # reason literal and dropped the real reason.
      local ref="" reason=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          -d|--reason) reason="$2"; shift 2 ;;
          *) if [ -z "$ref" ]; then ref="$1"; elif [ -z "$reason" ]; then reason="$1"; fi; shift ;;
        esac
      done
      [ -n "$ref" ] || { echo "hydra queue add: need <reference>" >&2; exit 2; }
      [ -n "$reason" ] || reason="Added by hydra CLI"
      _post "/queue" "{\"reference\":$(printf '%s' "$ref" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'),\"reason\":$(printf '%s' "$reason" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()))'),\"source\":\"hydra-cli\"}" ;;
    *   ) echo "hydra queue: need ls|add" >&2; exit 2 ;;
  esac
}

cmd_metrics() {
  local q=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --count) q="?count=$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  _get "/metrics${q}"
}

cmd_alerts() {
  case "${1:-}" in
    ls|"")
      shift || true
      local q=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --limit) q="?limit=$2"; shift 2 ;;
          *) shift ;;
        esac
      done
      _get "/alerts${q}" ;;
    dismiss-all) _post "/alerts/dismiss-all" ;;
    *          ) echo "hydra alerts: need ls|dismiss-all" >&2; exit 2 ;;
  esac
}

cmd_recommendations() {
  _get "/recommendations"
}

cmd_research() {
  case "${1:-}" in
    start  ) _post "/research/start" ;;
    force  ) _post "/research/force" ;;
    history)
      shift
      local q=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --limit) q="?limit=$2"; shift 2 ;;
          *) shift ;;
        esac
      done
      _get "/research/history${q}" ;;
    *      ) echo "hydra research: need start|force|history" >&2; exit 2 ;;
  esac
}

cmd_raw() {
  local method="${1:-}"
  local path="${2:-}"
  shift 2 || { echo "hydra raw: need <METHOD> <PATH>" >&2; exit 2; }
  local body=""
  # Issue #779: bind the request body from EITHER the --json flag OR the
  # first positional argument. Pre-fix, cmd_raw only honoured --json; a
  # positional `<body>` (the form all 14 `hydra raw POST` call-sites in
  # docs/operator-playbooks/ use) fell into the `*) shift` case and was
  # silently discarded â€” curl then POSTed an EMPTY body, so endpoints like
  # /metrics/record 400'd with "Missing cycleId". The body is forwarded
  # byte-for-byte by `curl -d` (multi-line and single-line both arrive
  # intact), so no stdin redirection / jq -c collapsing is needed. --json
  # still works (backward-compatible), and a bodyless POST is still valid.
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) body="$2"; shift 2 ;;
      *) if [ -z "$body" ]; then body="$1"; fi; shift ;;
    esac
  done
  case "$method" in
    GET)    _get "$path" ;;
    POST)   if [ -n "$body" ]; then _post "$path" "$body"; else _post "$path"; fi ;;
    PATCH)  [ -n "$body" ] || { echo "hydra raw PATCH: need --json '<body>'" >&2; exit 2; }
            _patch "$path" "$body" ;;
    DELETE) _delete "$path" ;;
    *)      echo "hydra raw: unsupported method '$method'" >&2; exit 2 ;;
  esac
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

[ "$#" -ge 1 ] || usage

case "$1" in
  -h|--help|help) usage 0 ;;
  health)          shift; cmd_health "$@" ;;
  scheduler)       shift; cmd_scheduler "$@" ;;
  brake)           shift; cmd_brake "$@" ;;
  cycle)           shift; cmd_cycle "$@" ;;
  backlog)         shift; cmd_backlog "$@" ;;
  queue)           shift; cmd_queue "$@" ;;
  metrics)         shift; cmd_metrics "$@" ;;
  alerts)          shift; cmd_alerts "$@" ;;
  recommendations) shift; cmd_recommendations "$@" ;;
  research)        shift; cmd_research "$@" ;;
  raw)             shift; cmd_raw "$@" ;;
  *)               echo "hydra: unknown command '$1'" >&2; usage ;;
esac
